---
import Button from "@/components/Button.astro";
import Counter from "@/components/Counter.astro";
import Layout from "@/layouts/Layout.astro";

const features = [
  {
    title: "TypeScript Strict",
    description: "Catch errors early. Strict mode enabled via astro/tsconfigs/strict.",
    icon: "TS",
  },
  {
    title: "Tailwind CSS v4",
    description: "CSS-first config with @theme. No tailwind.config file needed.",
    icon: "TW",
  },
  {
    title: "Vitest + Testing Library",
    description: "jsdom environment, globals enabled, and jest-dom matchers ready to go.",
    icon: "VT",
  },
  {
    title: "ESLint Flat Config",
    description: "Strict rules for Astro, TypeScript, and import sorting.",
    icon: "ES",
  },
  {
    title: "Prettier",
    description: "Consistent formatting with the Astro plugin. Runs on every save.",
    icon: "PR",
  },
  {
    title: "Husky + commitlint",
    description:
      "Pre-commit hooks enforce lint/format. Commit messages follow Conventional Commits.",
    icon: "GH",
  },
  {
    title: "GitHub Actions CI",
    description: "Type check, lint, format, test, and build on every push and PR.",
    icon: "CI",
  },
  {
    title: "Dependabot",
    description: "Weekly automated dependency updates grouped by ecosystem.",
    icon: "DB",
  },
  {
    title: "DevContainer",
    description: "One-click reproducible dev environment with all extensions pre-installed.",
    icon: "DC",
  },
];

const badges = [
  { label: "Astro 5", color: "text-orange-400 border-orange-900 bg-orange-950/40" },
  { label: "Tailwind v4", color: "text-cyan-400 border-cyan-900 bg-cyan-950/40" },
  { label: "TypeScript", color: "text-blue-400 border-blue-900 bg-blue-950/40" },
  { label: "Vitest", color: "text-green-400 border-green-900 bg-green-950/40" },
  { label: "Bun", color: "text-yellow-400 border-yellow-900 bg-yellow-950/40" },
  { label: "ESLint", color: "text-purple-400 border-purple-900 bg-purple-950/40" },
];
---

<Layout
  title="Astro Template"
  description="An opinionated Astro 5 starter with Tailwind CSS v4, TypeScript strict mode, Vitest, ESLint, and GitHub Actions."
>
  <main class="min-h-screen bg-gray-950 text-white">
    <!-- Hero -->
    <section class="flex flex-col items-center justify-center px-6 py-32 text-center">
      <div class="mb-8 flex flex-wrap justify-center gap-2">
        {
          badges.map(({ label, color }) => (
            <span class:list={["rounded-full border px-3 py-1 text-xs font-medium", color]}>
              {label}
            </span>
          ))
        }
      </div>
      <h1 class="mb-4 text-5xl font-bold tracking-tight sm:text-6xl">Astro Template</h1>
      <p class="mb-10 max-w-xl text-lg text-gray-400">
        An opinionated starting point for production-ready Astro sites. Everything configured,
        nothing in the way.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button
          href="https://github.com/abijith-suresh/astro-template"
          target="_blank"
          rel="noopener noreferrer"
        >
          Use this template
        </Button>
        <Button
          href="https://docs.astro.build"
          variant="outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Astro Docs
        </Button>
      </div>
    </section>

    <!-- Interactive Counter -->
    <section class="border-y border-gray-800 px-6 py-20">
      <div class="mx-auto max-w-sm text-center">
        <Counter initial={0} />
        <p class="mt-6 text-sm text-gray-600">Vanilla JS island — no framework required.</p>
      </div>
    </section>

    <!-- Feature Grid -->
    <section class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <h2 class="mb-2 text-center text-3xl font-bold">What's Included</h2>
        <p class="mb-12 text-center text-gray-400">
          Everything you need to ship, nothing you don't.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map(({ title, description, icon }) => (
              <div class="rounded-xl border border-gray-800 bg-gray-900/50 p-6 transition-colors hover:border-gray-700">
                <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg bg-gray-800 text-xs font-bold text-gray-300">
                  {icon}
                </div>
                <h3 class="mb-1 font-semibold">{title}</h3>
                <p class="text-sm text-gray-500">{description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
